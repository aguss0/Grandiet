// ============================================================
// SCHEMA PRISMA — Sistema de gestión dietética familiar
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USUARIOS Y ROLES
// ─────────────────────────────────────────

model Rol {
  id       Int      @id @default(autoincrement())
  nombre   String   @unique // "empleado" | "administrador"
  usuarios Usuario[]

  @@map("roles")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  passwordHash String   @map("password_hash")
  rolId        Int      @map("rol_id")
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  rol              Rol               @relation(fields: [rolId], references: [id])
  ventas           Venta[]
  movimientosStock MovimientoStock[]

  @@map("usuarios")
}

// ─────────────────────────────────────────
// CATÁLOGO DE PRODUCTOS
// ─────────────────────────────────────────

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]

  @@map("categorias")
}

model Producto {
  id           Int      @id @default(autoincrement())
  nombre       String
  categoriaId  Int      @map("categoria_id")
  marca        String?
  descripcion  String?
  precioCompra Decimal  @map("precio_compra") @db.Decimal(12, 2)
  precioVenta  Decimal  @map("precio_venta")  @db.Decimal(12, 2)
  stockActual  Int      @default(0) @map("stock_actual")
  stockMinimo  Int      @default(0) @map("stock_minimo")
  unidad       String   @default("unidades") // kg, g, unidades, litros, ml, etc.
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  categoria        Categoria         @relation(fields: [categoriaId], references: [id])
  ventas           Venta[]
  movimientosStock MovimientoStock[]

  @@map("productos")
}

// ─────────────────────────────────────────
// VENTAS
// ─────────────────────────────────────────

model Venta {
  id           Int      @id @default(autoincrement())
  productoId   Int      @map("producto_id")
  cantidad     Int
  precioVenta  Decimal  @map("precio_venta")  @db.Decimal(12, 2)
  precioCompra Decimal  @map("precio_compra") @db.Decimal(12, 2) // snapshot al momento de la venta
  ganancia     Decimal  @db.Decimal(12, 2)                        // (pv - pc) * cantidad
  usuarioId    Int      @map("usuario_id")
  fecha        DateTime @default(now())
  observaciones String?

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("ventas")
}

// ─────────────────────────────────────────
// MOVIMIENTOS DE STOCK
// ─────────────────────────────────────────

model MovimientoStock {
  id               Int             @id @default(autoincrement())
  productoId       Int             @map("producto_id")
  tipo             TipoMovimiento                          // INGRESO | VENTA | AJUSTE
  cantidad         Int                                     // positivo = ingreso, negativo = egreso
  stockAnterior    Int             @map("stock_anterior")
  stockPosterior   Int             @map("stock_posterior")
  precioReferencia Decimal?        @map("precio_referencia") @db.Decimal(12, 2)
  usuarioId        Int             @map("usuario_id")
  fecha            DateTime        @default(now())
  observaciones    String?
  ventaId          Int?            @map("venta_id")        // FK opcional, si el movimiento es de una venta

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("movimientos_stock")
}

enum TipoMovimiento {
  INGRESO
  VENTA
  AJUSTE
}
